{
  "manifest_version": 3,
  "name": "Crunchyroll Super Controller",
  "version": "1.1",
  "description": "Controle a velocidade, ative Picture-in-Picture e salve suas preferências no Crunchyroll.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "crunchyroll-super@arthur.dev"
    }
  }
}