{
  "manifest_version": 3,
  "name": "Crunchyroll Super Controller",
  "version": "1.1",
  "description": "Control your playback speed and save your preferences on Crunchyroll.",
  "permissions": ["activeTab", "storage"],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": ["content.js"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "crunchyroll-super@arthur.dev"
    }
  }
}